# =============================================================================
# CultivatED — Environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser at build
# time. Everything else is server-only (Next.js API routes, Firebase
# Functions, scripts).
# =============================================================================

# -----------------------------------------------------------------------------
# App identity
# -----------------------------------------------------------------------------
# Display name used across the UI and SEO metadata.
NEXT_PUBLIC_APP_NAME=CultivatED

# Public URL where the deployed app is reachable. Used for OpenGraph,
# sitemaps, transactional email links, QR codes, etc.
# In local dev, leave as http://localhost:3000.
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Firebase — client SDK config
# -----------------------------------------------------------------------------
# Get these from: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Firebase — admin SDK (server-only, used by scripts and API routes)
# -----------------------------------------------------------------------------
# Generate from: Firebase Console → Project Settings → Service accounts
# → Generate new private key (download JSON, then map fields below).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Google Gemini (AI tutor — server-only)
# -----------------------------------------------------------------------------
# Get a key at: https://aistudio.google.com/apikey
# The browser fetches ephemeral tokens via /api/gemini/live-token, so this
# never ships to the client.
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# AssemblyAI (voice transcription — server-only)
# -----------------------------------------------------------------------------
# Get a key at: https://www.assemblyai.com/dashboard/signup
# The browser hits /api/assemblyai/* proxy routes; this stays server-side.
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# -----------------------------------------------------------------------------
# Desmos calculator embed (public by design)
# -----------------------------------------------------------------------------
# Restrict by allowed domain in your Desmos developer dashboard.
NEXT_PUBLIC_DESMOS_API_KEY=your-desmos-api-key

# -----------------------------------------------------------------------------
# Email (Firebase Functions — set via `firebase functions:secrets:set`)
# -----------------------------------------------------------------------------
# These are NOT read from .env.local — they're Firebase secrets. Listed
# here for reference. To set:
#   firebase functions:secrets:set GMAIL_USER
#   firebase functions:secrets:set GMAIL_PASS    # Gmail App Password
#   firebase functions:secrets:set EMAIL_FROM    # e.g. "Acme <noreply@acme.com>"
#
# Optional: route every outgoing email to one address for QA.
# Set on the Functions runtime env, not as a secret.
# TEST_EMAIL_OVERRIDE=qa@example.com
#
# Optional: comma-separated allowlist of recipient emails for the email
# debug tool in /admin/email. Leave unset in production.
# ALLOWED_TEST_EMAILS=you@example.com,teammate@example.com

# -----------------------------------------------------------------------------
# Optional flags
# -----------------------------------------------------------------------------
# Set to "1" to load the commercial brand fonts ("DIN Round Pro", "Brasley")
# from public/. Requires running `npm run setup:fonts` first. See README.
# NEXT_PUBLIC_USE_BRAND_FONTS=0

# Comma-separated list of school names that get school-leaderboard access
# and partner-school onboarding flows. Leave empty to disable those gates.
# NEXT_PUBLIC_ALLOWED_SCHOOLS=Example High School,Another School

# Optional: username (lowercase) of a "house" account that automatically
# receives unlimited referral credit. Leave unset to disable.
# NEXT_PUBLIC_UNLIMITED_REFERRER_USERNAME=admin
