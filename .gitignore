# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/questions.json

# firebase
.firebase/
firebase-debug.log
*-debug.log
pglite-debug.log

# private assets (commercial fonts and other licensed material)
private-assets/

# brand fonts copied into public/ at build time by scripts/setup-fonts.sh
/public/brasley.otf
/public/DIN Round Pro/

# Google Search Console verification (deployment-specific)
/public/google*.html

# llms.txt is deploy-specific (contains absolute URLs to deployed instance)
/public/llms.txt

# Local Firebase project config (set your project with `firebase use --add`)
.firebaserc
